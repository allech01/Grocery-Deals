<?xml version="1.0" encoding="utf-8"?>

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="10dp">

        <TextView
            android:id="@+id/otp_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter OTP"
            android:textSize="24sp"

            android:textStyle="bold"
            android:textColor="#77944d"
            android:layout_marginTop="60dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <EditText
            android:id="@+id/otp_box_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#000000"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/otp_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/otp_box_2"
            app:layout_constraintWidth_percent="0.2" />

        <EditText
            android:id="@+id/otp_box_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#000000"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/otp_title"
            app:layout_constraintStart_toEndOf="@id/otp_box_1"
            app:layout_constraintEnd_toStartOf="@id/otp_box_3"
            app:layout_constraintWidth_percent="0.2" />

        <EditText
            android:id="@+id/otp_box_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#000000"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/otp_title"
            app:layout_constraintStart_toEndOf="@id/otp_box_2"
            app:layout_constraintEnd_toStartOf="@id/otp_box_4"
            app:layout_constraintWidth_percent="0.2" />

        <EditText
            android:id="@+id/otp_box_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#000000"
            android:textSize="18sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/otp_title"
            app:layout_constraintStart_toEndOf="@id/otp_box_3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.2" />

        <Button
            android:id="@+id/submit_otp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:layout_marginTop="40dp"
            android:text="Verify OTP"
            android:textSize="18sp"
            android:background="@drawable/round_corner"
            android:backgroundTint="#F5F5F5"
            android:textColor="#77944d"
            android:padding="20dp"
            app:layout_constraintTop_toBottomOf="@id/otp_box_4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

