<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- List Name Input -->
    <EditText
        android:id="@+id/edit_text_list_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter List Name"
        android:padding="16dp"
        android:layout_marginTop="40dp"/>

    <!-- Item Input -->
    <EditText
        android:id="@+id/edit_text_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Item"
        android:layout_below="@id/edit_text_list_name"
        android:padding="16dp"
        android:layout_marginTop="16dp"/>

    <!-- Add Item Button -->
    <Button
        android:id="@+id/button_add_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Add Item"
        android:layout_below="@id/edit_text_item"
        android:layout_marginTop="16dp"
        android:layout_alignParentLeft="true"/>

    <!-- Save List Button -->
    <Button
        android:id="@+id/button_save_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save List"
        android:layout_below="@id/button_add_item"
        android:layout_marginTop="16dp"
        android:layout_alignParentRight="true"/>

    <!-- TextView to display added items -->
    <TextView
        android:id="@+id/text_view_items"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Items will be listed here"
        android:layout_below="@id/button_save_list"
        android:layout_marginTop="16dp"
        android:padding="16dp" />

</RelativeLayout>
