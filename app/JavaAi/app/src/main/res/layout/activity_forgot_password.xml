<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginPageActivity"
    android:background="@color/white"
    >


    <ImageView
        android:id="@+id/c_logo"
        android:layout_width="150dp"
        android:layout_height="180dp"
        android:layout_alignParentRight="true"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="63dp"
        android:layout_marginRight="40dp"
        android:layout_marginBottom="20dp"
        android:padding="0dp"
        android:scaleType="centerInside"
        android:src="@drawable/logo7" />


    <TextView
        android:id="@+id/welcome_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Forgot \nPassword"
        android:textColor="#e76d67"
        android:textStyle="bold"
        android:textSize="26sp"
        android:layout_marginLeft="17dp"
        android:layout_marginTop="120dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:layout_below="@+id/welcome_2"
        android:layout_marginTop="40dp"
        android:background="@drawable/login_background"
        >
        <LinearLayout
            android:id="@+id/mailplusicon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="10dp"
            android:layout_marginTop="10dp"
            android:weightSum="5"
            android:paddingTop="40dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/mailicon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="5.5dp"
                android:src="@drawable/mail"
                android:layout_weight="0.5" />

            <EditText
                android:id="@+id/email"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:hint="Email"
                android:textSize="18sp"
                android:inputType="textEmailAddress"
                android:textColor="#333333"
                android:background="@null"
                android:layout_weight="4" />
        </LinearLayout>

        <View
            android:id="@+id/line"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_below="@id/mailplusicon"
            android:layout_marginStart="30dp"
            android:layout_marginEnd="30dp"
            android:background="#333333" />



        <Button
            android:id="@+id/send"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:layout_marginStart="0dp"
            android:layout_below="@+id/line"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:backgroundTint="#F5F5F5"
            android:background="@drawable/round_corner"
            android:padding="15dp"
            android:text="SEND"
            android:textColor="#77944d"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/not_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an Account?"
            android:layout_below="@+id/send"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="30dp"
            android:padding="0dp"
            android:layout_alignParentStart="true"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/signup3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign up"
            android:textColor="#77944d"
            android:background="@null"
            android:textSize="16sp"
            android:padding="0dp"
            android:layout_alignBaseline="@+id/not_account"
            android:layout_toEndOf="@id/not_account"
            android:layout_marginTop="10dp" />

        <FrameLayout
            android:id="@+id/fragmentContainerView"
            android:layout_marginTop="20dp"
            android:layout_below="@+id/signup3"
            android:layout_centerHorizontal="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />


    </RelativeLayout>

</RelativeLayout>
