<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginPageActivity"
    android:background="#FFFFFF"
    >


    <ImageView
        android:id="@+id/c_logo"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"
        android:layout_marginStart="20dp"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="20dp"
        android:layout_marginRight="0dp"
        android:layout_marginBottom="20dp"
        android:padding="0dp"
        android:scaleType="centerInside"
        android:src="@drawable/logo5" />

    <TextView
        android:id="@+id/welcome_2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hi ! \nWelcome Back,👋"
        android:textColor="#e76d67"
        android:textStyle="bold"
        android:textSize="26sp"
        android:layout_marginTop="120dp"
        android:layout_marginLeft="17dp"
      />


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:layout_centerVertical="true"
        android:layout_below="@+id/welcome_2"
        android:layout_marginTop="40dp"
        android:background="@drawable/login_background"
        >



        <EditText
            android:id="@+id/email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:hint="Username / Email"
            android:textSize="12sp"
            android:inputType="textEmailAddress"
            android:padding="18dp"
            android:textStyle="bold"
            android:background="@drawable/edit_background"
            android:textColor="#333333" />


        <LinearLayout
            android:id="@+id/passicon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_below="@+id/email"
            android:layout_marginTop="10dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/edit_background"
            android:padding="18dp"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textStyle="bold"
                android:hint="Password"
                android:textSize="12sp"
                android:inputType="textPassword"
                android:padding="0dp"
                android:textColor="#333333"
                android:background="@android:color/transparent" />


            <ImageView
                android:id="@+id/password_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/view"
                android:layout_marginEnd="10dp"
                android:contentDescription="Password Icon"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>




        <Button
            android:id="@+id/forget_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password?"
            android:textColor="#77944d"
            android:layout_alignBaseline="@+id/remember_me"
            android:layout_below="@+id/passicon"
            android:layout_alignParentEnd="true"
            android:layout_marginTop="10dp"
            android:layout_marginRight="20dp"
            android:background="@null"
            android:textSize="14sp"
            android:backgroundTint="@color/white" />


        <CheckBox
            android:id="@+id/remember_me"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/passicon"
            android:text="Remember Me"
            android:textSize="14sp"
            android:textColor="#77944d"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="20dp"
            android:layout_alignStart="@+id/passicon"
            android:layout_alignParentStart="true" />

        <Button
            android:id="@+id/login4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/remember_me"
            android:layout_alignParentStart="true"
            android:layout_margin="20dp"
            android:layout_marginStart="0dp"
            android:layout_marginTop="203dp"
            android:layout_marginBottom="20dp"
            android:backgroundTint="#F5F5F5"
            android:textStyle="bold"
            android:background="@drawable/round_corner"
            android:padding="15dp"
            android:text="LOGIN"
            android:textColor="#77944d"
            android:textSize="18sp"
            />

        <TextView
            android:id="@+id/not_account"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Don't have an Account?"
            android:layout_below="@+id/login4"
            android:textSize="14sp"
            android:layout_marginTop="10dp"
            android:layout_marginLeft="30dp"
            android:padding="0dp"
            android:textStyle="normal"
            android:layout_alignParentStart="true"
            android:textColor="@color/black" />

        <Button
            android:id="@+id/signup2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/white"
            android:text="Sign up"
            android:textColor="#77944d"
            android:textSize="16sp"
            android:background="@null"
            android:padding="0dp"
            android:layout_alignBaseline="@+id/not_account"
            android:layout_toEndOf="@id/not_account"
            android:layout_marginTop="10dp" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="20dp"
            android:layout_below="@+id/signup2">

            <TextView
                android:id="@+id/or_continue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Or Continue With"
                android:layout_marginLeft="12dp"
                android:textSize="14sp"
                android:textStyle="normal"
                android:layout_marginTop="20dp"
                android:textColor="@color/black"
                android:layout_centerVertical="true" />

            <ImageView
                android:id="@+id/appleid"
                android:layout_width="50dp"
                android:layout_height="52dp"
                android:src="@drawable/apple"
                android:layout_toStartOf="@+id/facebook"
                android:layout_centerVertical="true"
                android:layout_marginRight="5dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="20dp" />
            <ImageView
                android:id="@+id/facebook"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/facebook"
                android:layout_toStartOf="@+id/google"
                android:layout_centerVertical="true"
                android:layout_marginRight="5dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="20dp" />

            <ImageView
                android:id="@+id/google"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/google_icon"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:layout_marginRight="10dp"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginEnd="10dp"
                android:layout_marginBottom="20dp" />
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>
