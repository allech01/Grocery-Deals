<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ListFragment">

    <!-- TextView for "My Lists" in the top-left corner -->
    <TextView
        android:id="@+id/text_my_lists"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="My Lists"
        android:textStyle="bold"
        android:textSize="22sp"
        android:textColor="@android:color/black"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_margin="16dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:layout_below="@+id/text_my_lists"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/receylerview"/>


    <!-- Button for "+ NEW LIST" in the bottom-right corner -->
    <Button
        android:id="@+id/button_new_list"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="+ NEW LIST"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:padding="16dp"
        android:backgroundTint="@color/black"
        android:textColor="@android:color/white" />

</RelativeLayout>
