<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SettingFragment"
    android:background="#141f23">

   <!-- AdMob Banner Ad -->
   <com.google.android.gms.ads.AdView
       android:id="@+id/banner_ad_view1"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:layout_centerHorizontal="true"
       android:layout_alignParentTop="true"
       ads:adSize="BANNER"
       ads:adUnitId="@string/admob_banner_ad_unit_id"/>

   <!-- Show Ad Button -->
   <Button
       android:id="@+id/btn_show1"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:textSize="20sp"
       android:text="Show Ad"
       android:padding="10dp"
       android:textStyle="bold"
       android:layout_centerInParent="true"/>

   <!-- Login Button -->
   <Button
       android:id="@+id/button_login1"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:text="Login"
       android:layout_below="@id/btn_show1"
       android:layout_centerHorizontal="true"
       android:layout_marginTop="20dp"/>

   <!-- Logout Button -->
   <Button
       android:id="@+id/button_logout1"
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:text="Logout"
       android:layout_below="@id/button_login1"
       android:layout_centerHorizontal="true"
       android:layout_marginTop="20dp"/>
</RelativeLayout>
